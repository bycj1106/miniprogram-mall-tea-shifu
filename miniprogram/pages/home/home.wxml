<view class="container">
  <view class="header">
    <view class="brand">
      <text class="brand-text">拾福茶仓</text>
    </view>
    <view class="search-bar" bindtap="onSearch">
      <icon type="search" size="16" color="#999"/>
      <text class="search-placeholder">搜索好茶...</text>
    </view>
  </view>

  <swiper class="banner" indicator-dots autoplay circular indicator-active-color="#556B2F">
    <swiper-item wx:for="{{banners}}" wx:key="_id">
      <image class="banner-image" src="{{item.image}}" mode="aspectFill" bindtap="goToCategory" data-url="{{item.link}}"/>
      <view class="banner-title">{{item.title}}</view>
    </swiper-item>
  </swiper>

  <view class="categories">
    <view class="category-item" bindtap="goToProducts" data-tag="master">
      <view class="category-icon">👑</view>
      <text class="category-name">大师甄选</text>
    </view>
    <view class="category-item" bindtap="goToProducts" data-tag="gift">
      <view class="category-icon">🎁</view>
      <text class="category-name">礼盒专区</text>
    </view>
    <view class="category-item" bindtap="goToProducts" data-tag="new">
      <view class="category-icon">🍃</view>
      <text class="category-name">新茶尝鲜</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">热销产品</text>
      <view class="tabs">
        <text class="tab {{activeTab === 'hot' ? 'active' : ''}}" bindtap="switchTab" data-tab="hot">热销</text>
        <text class="tab {{activeTab === 'new' ? 'active' : ''}}" bindtap="switchTab" data-tab="new">新品</text>
      </view>
    </view>

    <view class="product-grid">
      <view class="product-card" wx:for="{{activeTab === 'hot' ? hotProducts : newProducts}}" wx:key="_id" bindtap="goToProduct" data-id="{{item._id}}">
        <image class="product-image" src="{{item.images[0]}}" mode="aspectFill"/>
        <view class="product-tags" wx:if="{{item.isHot || item.isNew}}">
          <text class="tag {{item.isHot ? 'tag-hot' : ''}} {{item.isNew ? 'tag-new' : ''}}">{{item.isHot ? '热销' : ''}}{{item.isNew ? '新品' : ''}}</text>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-flavor">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index" class="flavor-tag">{{tag}}</text>
          </view>
          <view class="product-price">
            <text class="price-retail">¥{{item.priceRetail}}</text>
            <text class="price-discount">¥{{item.priceDiscount}}</text>
            <view class="seal" wx:if="{{item.priceRetail > item.priceDiscount}}">
              <text>省{{item.priceRetail - item.priceDiscount}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
