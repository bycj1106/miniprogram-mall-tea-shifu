.header {
  background: linear-gradient(135deg, #556B2F 0%, #3D4A22 100%);
  padding: 30rpx 30rpx 40rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand {
  text-align: center;
  margin-bottom: 24rpx;
}

.brand-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.search-bar {
  background: #FFFEFA;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.banner {
  height: 360rpx;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.categories {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  background: var(--bg-card);
  margin: 20rpx;
  border-radius: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #F3F0E6 0%, #E8E4D6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  border: 2rpx solid var(--border-color);
}

.category-name {
  font-size: 24rpx;
  color: var(--text-ink);
}

.section {
  padding: 0 20rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-ink);
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

.tabs {
  display: flex;
  gap: 30rpx;
}

.tab {
  font-size: 26rpx;
  color: var(--text-muted);
  padding-bottom: 8rpx;
  position: relative;
}

.tab.active {
  color: var(--primary);
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.product-image {
  width: 100%;
  height: 280rpx;
}

.product-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  gap: 8rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 26rpx;
  color: var(--text-ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.product-flavor {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.flavor-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: rgba(85, 107, 47, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.product-price {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.price-retail {
  color: var(--text-muted);
  text-decoration: line-through;
  font-size: 22rpx;
}

.price-discount {
  color: var(--accent-red);
  font-size: 30rpx;
  font-weight: bold;
  font-family: Georgia, serif;
}

.seal {
  width: 52rpx;
  height: 52rpx;
  background: var(--accent-red);
  border-radius: 50%;
  color: #fff;
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  margin-left: auto;
}
