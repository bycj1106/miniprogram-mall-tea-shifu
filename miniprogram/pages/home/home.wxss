.header {
  background: linear-gradient(135deg, #556B2F 0%, #3D4A22 100%);
  padding: 32rpx 30rpx 44rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand {
  text-align: center;
  margin-bottom: 28rpx;
}

.brand-text {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.search-bar {
  background: #FFFEFA;
  border-radius: 44rpx;
  padding: 18rpx 32rpx;
  display: flex;
  align-items: center;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.banner {
  height: 380rpx;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  padding: 14rpx 28rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.categories {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  background: var(--bg-card);
  margin: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(85, 107, 47, 0.08);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #F3F0E6 0%, #E8E4D6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border: 3rpx solid var(--border-color);
  margin-bottom: 16rpx;
}

.category-name {
  font-size: 26rpx;
  color: var(--text-ink);
  font-weight: 500;
}

.section {
  padding: 0 20rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 20rpx 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-ink);
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary) 0%, #6B8E23 100%);
  border-radius: 4rpx;
}

.tabs {
  display: flex;
}

.tab {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 10rpx 20rpx;
  position: relative;
}

.tab.active {
  color: var(--primary);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
}

.product-card {
  width: calc(50% - 15rpx);
  background: var(--bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(85, 107, 47, 0.1);
  position: relative;
  margin-bottom: 20rpx;
}

.product-card:nth-child(2n+1) {
  margin-right: 20rpx;
}

.product-image {
  width: 100%;
  height: 280rpx;
}

.product-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 28rpx;
  color: var(--text-ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.product-flavor {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.flavor-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: rgba(85, 107, 47, 0.1);
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.product-price {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.price-retail {
  color: var(--text-muted);
  text-decoration: line-through;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.price-discount {
  color: var(--accent-red);
  font-size: 32rpx;
  font-weight: 700;
  font-family: Georgia, serif;
}

.seal {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #A93226 0%, #7B241C 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  margin-left: auto;
  box-shadow: 0 4rpx 8rpx rgba(169, 50, 38, 0.3);
}
