.category-tabs {
  background: var(--bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid var(--border-color);
}

.tabs-wrapper {
  display: flex;
  padding: 0 20rpx;
  white-space: nowrap;
}

.tab {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-light);
  position: relative;
  display: inline-block;
  flex-shrink: 0;
}

.tab.active {
  color: var(--primary);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

.product-card {
  width: calc(50% - 15rpx);
  background: var(--bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(85, 107, 47, 0.1);
  position: relative;
  margin-bottom: 20rpx;
}

.product-card:nth-child(2n+1) {
  margin-right: 20rpx;
}

.product-image {
  width: 100%;
  height: 280rpx;
}

.product-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
}

.tag {
  font-size: 22rpx;
  color: #fff;
  background: var(--accent-red);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.tag + .tag {
  margin-left: 10rpx;
}

.tag {
  font-size: 20rpx;
  color: #fff;
  background: var(--accent-red);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-new {
  background: var(--primary);
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 26rpx;
  color: var(--text-ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.product-flavor {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.flavor-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: rgba(85, 107, 47, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.product-price {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.price-retail {
  color: var(--text-muted);
  text-decoration: line-through;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.price-discount {
  color: var(--accent-red);
  font-size: 32rpx;
  font-weight: 700;
  font-family: Georgia, serif;
}

.seal {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #A93226 0%, #7B241C 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  margin-left: auto;
  box-shadow: 0 4rpx 8rpx rgba(169, 50, 38, 0.3);
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}
