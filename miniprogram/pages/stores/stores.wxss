.stores-list {
  padding: 24rpx;
}

.store-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(85, 107, 47, 0.1);
}

.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-ink);
}

.store-distance {
  font-size: 26rpx;
  color: var(--primary);
  background: rgba(85, 107, 47, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.store-address {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.address-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.address-text {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.5;
  flex: 1;
}

.store-actions {
  display: flex;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.nav-btn {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  margin-right: 16rpx;
}

.call-btn {
  background: var(--bg-paper);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.contact-section {
  background: var(--bg-card);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(85, 107, 47, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-ink);
  margin-bottom: 28rpx;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary) 0%, #6B8E23 100%);
  border-radius: 4rpx;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 30rpx;
  color: var(--text-light);
}

.contact-value {
  font-size: 30rpx;
  color: var(--text-ink);
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}
