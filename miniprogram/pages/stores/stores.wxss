.stores-list {
  padding: 20rpx;
}

.store-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.store-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-ink);
}

.store-distance {
  font-size: 24rpx;
  color: var(--primary);
  background: rgba(85, 107, 47, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.store-address {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.address-icon {
  font-size: 28rpx;
  margin-top: 4rpx;
}

.address-text {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
  flex: 1;
}

.store-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.nav-btn {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
}

.call-btn {
  background: var(--bg-paper);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-icon {
  font-size: 28rpx;
}

.contact-section {
  background: var(--bg-card);
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-ink);
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: var(--text-light);
}

.contact-value {
  font-size: 28rpx;
  color: var(--text-ink);
}
