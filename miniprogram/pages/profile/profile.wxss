.profile-header {
  background: linear-gradient(135deg, #556B2F 0%, #3D4A22 100%);
  padding: 60rpx 30rpx;
  display: flex;
  justify-content: center;
}

.user-info, .login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-bottom: 20rpx;
}

.nickname {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.level-badge {
  background: var(--accent-gold);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.level-text {
  font-size: 22rpx;
  color: #fff;
}

.login-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.stats-section {
  background: var(--bg-card);
  margin: -40rpx 20rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 10;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-ink);
  font-family: Georgia, serif;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: var(--border-color);
}

.menu-section {
  background: var(--bg-card);
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-name {
  font-size: 28rpx;
  color: var(--text-ink);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}
