.profile-header {
  background: linear-gradient(135deg, #556B2F 0%, #3D4A22 100%);
  padding: 64rpx 30rpx;
  display: flex;
  justify-content: center;
}

.user-info, .login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.3);
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.nickname {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.level-badge {
  background: linear-gradient(135deg, #C9A227 0%, #B8860B 100%);
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(201, 162, 39, 0.3);
}

.level-text {
  font-size: 24rpx;
  color: #fff;
}

.login-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.85);
}
.user-info, .login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-bottom: 20rpx;
}

.nickname {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.level-badge {
  background: var(--accent-gold);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.level-text {
  font-size: 22rpx;
  color: #fff;
}

.login-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.stats-section {
  background: var(--bg-card);
  margin: -48rpx 24rpx 24rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 36rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(85, 107, 47, 0.1);
  position: relative;
  z-index: 10;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-ink);
  font-family: Georgia, serif;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-light);
}

.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: var(--border-color);
}

.menu-section {
  background: var(--bg-card);
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(85, 107, 47, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-name {
  font-size: 30rpx;
  color: var(--text-ink);
}

.menu-arrow {
  font-size: 34rpx;
  color: var(--text-muted);
}
