.product-images {
  height: 750rpx;
  position: relative;
}

.image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.product-header {
  background: var(--bg-card);
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.tags {
  display: flex;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 24rpx;
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.tag-hot {
  background: linear-gradient(135deg, #A93226 0%, #7B241C 100%);
}

.tag-new {
  background: linear-gradient(135deg, var(--primary) 0%, #6B8E23 100%);
}

.product-name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-ink);
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.product-meta {
  display: flex;
}

.meta-item {
  font-size: 26rpx;
  color: var(--text-light);
  margin-right: 32rpx;
}

.price-section {
  background: var(--bg-card);
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 26rpx;
  color: var(--accent-red);
  background: rgba(169, 50, 38, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  margin-right: 18rpx;
}

.price-discount {
  font-size: 52rpx;
  color: var(--accent-red);
  font-weight: 700;
  font-family: Georgia, serif;
}

.price-retail {
  font-size: 28rpx;
  color: var(--text-muted);
  text-decoration: line-through;
  margin-left: 18rpx;
}

.save-info {
  background: linear-gradient(135deg, #A93226 0%, #7B241C 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(169, 50, 38, 0.3);
}

.save-amount {
  font-size: 26rpx;
}

.section {
  background: var(--bg-card);
  margin-top: 24rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-ink);
  margin-bottom: 28rpx;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary) 0%, #6B8E23 100%);
  border-radius: 4rpx;
}

.radar-container {
  position: relative;
  height: 500rpx;
}

.radar-chart {
  width: 100%;
  height: 100%;
}

.radar-labels {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.radar-label {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.radar-label text {
  font-size: 24rpx;
  color: var(--text-light);
}

.radar-label .value {
  font-size: 30rpx;
  color: var(--primary);
  font-weight: 600;
}

.description {
  font-size: 30rpx;
  color: var(--text-light);
  line-height: 1.8;
}

.flavor-tags {
  display: flex;
  flex-wrap: wrap;
}

.flavor-tag {
  font-size: 28rpx;
  color: var(--primary);
  background: rgba(85, 107, 47, 0.1);
  padding: 14rpx 28rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -6rpx 20rpx rgba(85, 107, 47, 0.1);
}

.action-icons {
  display: flex;
  margin-right: 32rpx;
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 48rpx;
}

.action-icon .icon {
  font-size: 44rpx;
}

.action-icon .icon-text {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

.btn-cart {
  flex: 1;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  text-align: center;
  padding: 26rpx;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(85, 107, 47, 0.3);
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 500rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}
