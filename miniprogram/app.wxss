page {
  --bg-paper: #F3F0E6;
  --bg-card: #FFFEFA;
  --primary: #556B2F;
  --primary-dark: #3D4A22;
  --accent-red: #A93226;
  --accent-gold: #C9A227;
  --text-ink: #2B2B2B;
  --text-light: #595959;
  --text-muted: #999999;
  --border-color: #D4C9B5;
  
  background-color: var(--bg-paper);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Serif SC", serif;
  color: var(--text-ink);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 22rpx 44rpx;
  border: none;
  text-align: center;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.9;
}

.price-retail {
  color: var(--text-muted);
  text-decoration: line-through;
  font-size: 24rpx;
}

.price-discount {
  color: var(--accent-red);
  font-size: 34rpx;
  font-weight: 700;
  font-family: Georgia, serif;
}

.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(85, 107, 47, 0.08);
}

.tag-hot {
  background: linear-gradient(135deg, #A93226 0%, #7B241C 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.tag-new {
  background: linear-gradient(135deg, var(--primary) 0%, #6B8E23 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.seal {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #A93226 0%, #7B241C 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  box-shadow: 0 4rpx 12rpx rgba(169, 50, 38, 0.3);
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}
